Int main() {
    return boolfunc(0);
}

Int boolfunc(Int x) {
    if (True && True) {
        x = x + 1;
    }
    if (False && True) {
        x = x - 1;
    }
    if (False || False) {
        x = x - 1;
    }
    if (True || False) {
        x = x + 2;
    }
    if (5 < 6 && 5<=6 && 6<=6) {
        x = x + 3;
    }
    if (6 > 5 && 6>=5 && 6>=6) {
        x = x + 4;
    }
    if (10 == 10 && 9 != 10) {
        x = x + 5;
    }
    return x;
}
