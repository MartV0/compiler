Void print(&Char str) {
    syscall!(1, 1, str, string_len(str));
}

Int string_len(&Char str) {
    Int len;
    len = 0;
    while ((Int)str[len] != 0) {
        len = len + 1;
    }
    return len;
}

&Void alloc(Int bytes) {
    return syscall!(
        9, //mmap
        0, //null address
        bytes,
        3, // read (1) + write (2)
        34, // private (2) + anon (32)
        0, // no fd?
        0  // no offset
    );
}
